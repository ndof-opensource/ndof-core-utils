# Team-wide formatting. Enforced in CI (clang-format --dry-run -Werror).
# Version-pinned via the dev image's clang-format; format only inside the
# container (or with the same major version) to avoid churn.
BasedOnStyle: LLVM
Standard: Latest
IndentWidth: 4
ColumnLimit: 100
PointerAlignment: Left
DerivePointerAlignment: false
AllowShortFunctionsOnASingleLine: Inline
InsertNewlineAtEOF: true
